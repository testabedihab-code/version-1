{
  "name": "nurse-dashboard-app",
  "version": "1.0.0",
  "private": true,
  "description": "Nurse Dashboard PWA — لوحة الممرضة",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run build && npx cap sync android && npx cap open android",
    "cap:ios": "npm run build && npx cap sync ios && npx cap open ios",
    "icons": "node scripts/generate-icons.js",
    "deploy:firebase": "npm run build && firebase deploy",
    "deploy:vercel": "vercel --prod"
  },
  "dependencies": {
    "firebase": "^10.7.1"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0",
    "vite-plugin-pwa": "^0.19.0"
  }
}
